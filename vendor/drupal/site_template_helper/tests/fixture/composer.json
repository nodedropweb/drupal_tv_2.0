{
    "name": "drupal/recommended-project",
    "repositories": [
        {
            "type": "path",
            "url": "./fake-template"
        },
        {
            "type": "path",
            "url": "../.."
        },
        {
            "type": "composer",
            "url": "vendor.json"
        },
        {
            "packagist.org": false
        }
    ],
    "require": {
        "composer/installers": "^2.3",
        "drupal/core": "*",
        "drupal/fake_site_template": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/site_template_helper": true
        }
    },
    "extra": {
        "installer-paths": {
            "core": ["type:drupal-core"]
        }
    }
}
